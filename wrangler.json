{
  "name": "domain-drop-watcher",
  "main": "src/worker.ts",
  "compatibility_date": "2026-04-22",
  "triggers": { "crons": ["* * * * *"] },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "domain-drop-watcher",
      "database_id": "00000000-0000-0000-0000-000000000000"
    }
  ],
  "kv_namespaces": [
    { "binding": "EVENTS", "id": "00000000000000000000000000000001" },
    { "binding": "BOOTSTRAP", "id": "00000000000000000000000000000002" }
  ],
  "send_email": [
    { "type": "send_email", "name": "EMAIL" }
  ],
  "assets": {
    "directory": "./public",
    "binding": "ASSETS",
    "run_worker_first": true
  },
  "env": {
    "demo": {
      "name": "domain-drop-watcher-demo",
      "vars": { "DEMO_MODE": "1", "DEMO_ADMIN_EMAIL": "ray@oit.co" },
      "custom_domains": ["ddw.oitlabs.com"],
      "d1_databases": [
        { "binding": "DB", "database_name": "domain-drop-watcher-demo", "database_id": "b5c26bf7-b635-4c05-97c3-85f47bb0a7d1" }
      ],
      "kv_namespaces": [
        { "binding": "EVENTS",    "id": "84ec0e98ca43461eb7302e51c638bc0c" },
        { "binding": "BOOTSTRAP", "id": "5a64f27c0dbc4ca09fb3077ac997fa3d" }
      ]
    }
  }
}
