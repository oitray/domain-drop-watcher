{
  "name": "domain-drop-watcher",
  "version": "0.1.0",
  "type": "module",
  "private": false,
  "license": "MIT",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "postdeploy": "wrangler d1 execute domain-drop-watcher --file=schema.sql --remote && node scripts/bootstrap-admin-token.mjs",
